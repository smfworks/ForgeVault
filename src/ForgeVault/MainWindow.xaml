<Window x:Class="ForgeVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeVault" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0">
            <ToolBar>
                <Button x:Name="OpenVaultButton" Content="Open Vault" Click="OpenVaultButton_Click" />
                <Button x:Name="NewNoteButton" Content="New Note" Click="NewNoteButton_Click" />
                <Button x:Name="GraphButton" Content="Graph" Click="GraphButton_Click" />
                <Button x:Name="AiChatButton" Content="AI Chat" Click="AiChatButton_Click" />
            </ToolBar>
        </ToolBarTray>

        <!-- Main content: file tree + editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TreeView x:Name="VaultTree" Grid.Column="0" />

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="Editor" Grid.Column="0" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14" />
                <Frame x:Name="PreviewFrame" Grid.Column="1" NavigationUIVisibility="Hidden" />
            </Grid>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="No vault opened" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
