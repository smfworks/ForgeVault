<Window x:Class="ForgeVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ForgeVault" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" IsLocked="True">
            <ToolBar>
                <Button x:Name="OpenVaultButton" Content="Open Vault" Click="OpenVaultButton_Click" />
                <Button x:Name="NewNoteButton" Content="New Note" Click="NewNoteButton_Click" />
                <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" />
                <Button x:Name="GraphButton" Content="Graph" Click="GraphButton_Click" />
                <Button x:Name="AiChatButton" Content="AI Chat" Click="AiChatButton_Click" />
            </ToolBar>
        </ToolBarTray>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Vault" VerticalAlignment="Center" Margin="4,0" />
            <TextBox x:Name="SearchBox" Grid.Column="1" KeyDown="SearchBox_KeyDown" />
            <Button x:Name="SearchButton" Grid.Column="2" Content="Search" Click="SearchButton_Click" />
        </Grid>

        <!-- Main content: file tree + editor -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TreeView x:Name="VaultTree" Grid.Column="0" SelectedItemChanged="VaultTree_SelectedItemChanged" />

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" />

            <TextBox x:Name="Editor" Grid.Column="2" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="14" VerticalScrollBarVisibility="Auto" TextChanged="Editor_TextChanged" />

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" />

            <Border Grid.Column="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <WebBrowser x:Name="PreviewBrowser" />
            </Border>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="No vault opened" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
