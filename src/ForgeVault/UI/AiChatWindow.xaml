<Window x:Class="ForgeVault.AiChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Chat" Height="600" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <TextBlock Text="Model:" VerticalAlignment="Center" Margin="4,0" />
            <TextBox x:Name="ModelBox" Text="llama3" Width="150" />
            <CheckBox x:Name="UseVaultContext" Content="Use vault context" IsChecked="True" Margin="8,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="ChatHistory" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" />
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ChatInput" Grid.Column="0" KeyDown="ChatInput_KeyDown" />
            <Button x:Name="SendButton" Grid.Column="1" Content="Send" Click="SendButton_Click" />
        </Grid>
    </Grid>
</Window>
