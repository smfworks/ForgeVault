<Window x:Class="ForgeVault.SearchResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Results" Height="500" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <ListView x:Name="ResultsList" MouseDoubleClick="ResultsList_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="200" />
                    <GridViewColumn Header="Path" DisplayMemberBinding="{Binding FilePath}" Width="300" />
                    <GridViewColumn Header="Rank" DisplayMemberBinding="{Binding Rank}" Width="60" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
